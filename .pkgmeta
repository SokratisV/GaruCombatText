# BigWigsMods packager config. The repo root *is* the addon, so the package is
# built from here and named "GaruCombatText" (the folder players extract into AddOns).
package-as: GaruCombatText

# Self-contained — no libraries pulled as externals, so no externals block and no
# separate "nolib" zip.
enable-nolib-creation: no

# Repo-meta files that shouldn't ship inside the addon zip.
ignore:
  - .github
  - .gitattributes
  - .gitignore
  - .pkgmeta
  - logo.png   # CurseForge project art — not needed inside the addon zip
